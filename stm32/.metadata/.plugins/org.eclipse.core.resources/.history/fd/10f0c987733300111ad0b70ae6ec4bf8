int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset all peripherals and initialize HAL */
  HAL_Init();

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_TIM3_Init();
  MX_USART1_UART_Init();

  /* USER CODE BEGIN 2 */

  // Start PWM output
  if (HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1) != HAL_OK)
  {
      Error_Handler();
  }

  // Start fan at 0% until potentiometer is read
  set_pwm_percent(0.0f);

  // Send startup text and CSV header
  uart_send_line("STM32 fan control telemetry start\r\n");
  uart_send_line("t_s,voltage_v,pot_voltage_v,pot_percent,pwm_pct,pwm_freq_hz\r\n");

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    // Time since boot in seconds
    float t_s = HAL_GetTick() / 1000.0f;

    // Read adc measurements */
    float voltage_v = read_voltage_v();
    float pot_voltage_v = read_pot_voltage_v();
    float pot_percent = read_pot_percent();

//      Fan control behavior:
//      The potentiometer directly controls PWM duty cycle.
//      More potentiometer voltage means higher PWM duty cycle means faster fan.
    set_pwm_percent(pot_percent);

    // Format telemetry as CSV
    snprintf(uart_msg, sizeof(uart_msg),
             "%.3f,%.3f,%.3f,%.1f,%.1f,%lu\r\n",
             t_s,
             voltage_v,
             pot_voltage_v,
             pot_percent,
             pwm_pct,
             (unsigned long)PWM_FREQ_HZ);

    // Send telemetry line
    uart_send_line(uart_msg);

    // Update every 100 ms
    HAL_Delay(TELEMETRY_PERIOD_MS);

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

