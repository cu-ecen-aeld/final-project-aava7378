/**
  * @brief Reads one ADC channel using polling.
  * @param channel ADC channel to read.
  * @retval Raw 12-bit ADC value (0 to 4095).
  * This helper reconfigures ADC1 each time so the same ADC can read
  * multiple analog inputs one at a time.
  */
static uint32_t read_adc_channel(uint32_t channel)
{
    ADC_ChannelConfTypeDef sConfig = {0};

    // Select which ADC channel to sample
    sConfig.Channel = channel;
    sConfig.Rank = ADC_REGULAR_RANK_1;
    sConfig.SamplingTime = ADC_SAMPLETIME_71CYCLES_5;

    if (HAL_ADC_ConfigChannel(&hadc1, &sConfig) != HAL_OK)
    {
        Error_Handler();
    }

    // Start conversion
    if (HAL_ADC_Start(&hadc1) != HAL_OK)
    {
        Error_Handler();
    }

    // Wait until the conversion finishes
    if (HAL_ADC_PollForConversion(&hadc1, HAL_MAX_DELAY) != HAL_OK)
    {
        Error_Handler();
    }

    // Read the conversion result
    uint32_t raw = HAL_ADC_GetValue(&hadc1);

    // Stop ADC after the one-shot conversion
    if (HAL_ADC_Stop(&hadc1) != HAL_OK)
    {
        Error_Handler();
    }

    return raw;
}

/**
  * @brief Converts a raw ADC count into volts.
  * @param raw 12-bit ADC result.
  * @retval Voltage at the ADC pin.
  *
  * Formula:
  * volts = raw * VREF / ADC_MAX
  */
static float adc_to_volts(uint32_t raw)
{
    return ((float)raw * VREF) / ADC_MAX;
}

// Reads a voltage on ADC channel 0.
// Voltage in volts.
static float read_voltage_v(void)
{
    uint32_t raw = read_adc_channel(ADC_CHANNEL_0);
    float adc_v = adc_to_volts(raw);
    return adc_v * VOLTAGE_GAIN;
}

/**
  * @brief Reads potentiometer wiper voltage from ADC channel 1.
  * @retval Potentiometer voltage in volts.
  */
static float read_pot_voltage_v(void)
{
    uint32_t raw = read_adc_channel(ADC_CHANNEL_1);
    return adc_to_volts(raw);
}

/**
  * @brief Converts potentiometer voltage into 0 to 100 percent.
  * @retval Potentiometer position as a percentage.
  * 0 V   -> 0%
  * 3.3 V -> 100%
  */
static float read_pot_percent(void)
{
    float pot_v = read_pot_voltage_v();
    float pct = (pot_v / VREF) * 100.0f;

    // Clamp result for safety
    if (pct < 0.0f)
    {
        pct = 0.0f;
    }
    if (pct > 100.0f)
    {
        pct = 100.0f;
    }

    return pct;
}

/**
  * @brief Sets PWM duty cycle as a percentage.
  * @param pct Duty cycle from 0 to 100.
  * This converts a percent into the timer compare value
  * used by the STM32 PWM hardware.
  */
static void set_pwm_percent(float pct)
{
    if (pct < 0.0f)
    {
        pct = 0.0f;
    }
    if (pct > 100.0f)
    {
        pct = 100.0f;
    }

    // Save current PWM percentage so telemetry reports the same value
    pwm_pct = pct;

    // ARR determines the PWM period
    uint32_t arr = __HAL_TIM_GET_AUTORELOAD(&htim3);

    // Convert percent into compare value
    uint32_t compare = (uint32_t)((pct / 100.0f) * (float)(arr + 1U));

    // Update timer compare register
    __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, compare);
}

/**
  * @brief Sends a text line over UART.
  * UART is used here for simple CSV telemetry output that can be parsed by
  * Pi 4.
  */
static void uart_send_line(const char *s)
{
    if (HAL_UART_Transmit(&huart1, (uint8_t *)s, strlen(s), HAL_MAX_DELAY) != HAL_OK)
    {
        Error_Handler();
    }
}
